<p class="post-meta">
  <span class="post-meta-item">Publicado em <time datetime="{{ date | htmlDateString }}">{{ date | shortDate }}</time></span>
  {%- if updated %}
  <span class="post-meta-sep">·</span>
  <span class="post-meta-item">Atualizado em <time datetime="{{ updated | htmlDateString }}">{{ updated | shortDate }}</time></span>
  {%- endif %}
  {%- if tags and tags.length %}
  <span class="post-meta-sep">·</span>
  <span class="post-meta-item post-meta-tags">
    {%- for tag in tags %}<a href="/tags/{{ tag }}/">#{{ tag }}</a>{{ " " if not loop.last }}{%- endfor %}
  </span>
  {%- endif %}
</p>
