---
layout: base.njk
bodyClass: post
---
<article>
  <h1>{{ title }}</h1>
  <p><time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time></p>
  {%- if tags %}
  <p class="tags">
    {%- for tag in tags %}
    <a href="{{ ("/tags/" + tag + "/") | url }}">#{{ tag }}</a>
    {%- endfor %}
  </p>
  {%- endif %}
  {{ content | safe }}
</article>
