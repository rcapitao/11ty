---
layout: base.njk
title: Início
---
<h1>{{ metadata.title }}</h1>
<p>{{ metadata.description }}</p>

<h2>Últimos posts</h2>
<ul class="post-list">
  {%- for post in collections.posts %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
  </li>
  {%- endfor %}
</ul>
