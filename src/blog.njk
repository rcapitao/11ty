---
layout: base.njk
title: Blog
permalink: /blog/
---
{%- set groups = collections.posts | groupPostsByYearMonth %}
<h1>Blog</h1>

<div class="bearming-archive-controls">
  <div class="bearming-archive-select">
    <select onchange="setArchiveYear(this.value)" aria-label="Selecionar ano">
      <option value="all">Todos os anos ({{ collections.posts.length }})</option>
      {%- for group in groups %}
      <option value="{{ group.year }}">{{ group.year }} ({{ group.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <div class="archive-type-filter" role="group" aria-label="Filtrar por tipo">
    <button type="button" class="archive-type-pill" data-type="posts" onclick="toggleArchiveType('posts', this)">#posts</button>
    <button type="button" class="archive-type-pill" data-type="notas" onclick="toggleArchiveType('notas', this)">#notas</button>
  </div>
  <p class="archive-type-status" hidden>
    Filtrando por <strong class="archive-type-status-label"></strong> ·
    <button type="button" class="archive-type-clear" onclick="clearArchiveType()">limpar filtro</button>
  </p>
</div>

{%- for group in groups %}
<section class="archive-year" data-year="{{ group.year }}">
  <h2>{{ group.year }} <span class="bearming-archive-count">({{ group.count }} post{{ "s" if group.count != 1 }})</span></h2>
  {%- for month in group.months %}
  <div class="archive-month-group">
    <h3 class="bearming-archive-month">{{ month.name }} de {{ group.year }} <span class="bearming-archive-count">({{ month.count }} post{{ "s" if month.count != 1 }})</span></h3>
    <ul class="blog-posts">
      {%- for post in month.posts %}
      <li data-type="{{ 'notas' if post.data.tags and 'notas' in post.data.tags else 'posts' }}">
        <span>{{ post.date | shortDate }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      {%- endfor %}
    </ul>
  </div>
  {%- endfor %}
</section>
{%- endfor %}

<script>
  var archiveType = "all";
  var archiveYear = "all";

  function applyArchiveFilters() {
    document.querySelectorAll(".archive-year").forEach(function (year) {
      var yearMatches = archiveYear === "all" || year.dataset.year === archiveYear;
      if (!yearMatches) {
        year.hidden = true;
        return;
      }
      var yearHasVisible = false;
      year.querySelectorAll(".archive-month-group").forEach(function (group) {
        var monthHasVisible = false;
        group.querySelectorAll("li[data-type]").forEach(function (li) {
          var show = archiveType === "all" || li.dataset.type === archiveType;
          li.hidden = !show;
          if (show) monthHasVisible = true;
        });
        group.hidden = !monthHasVisible;
        if (monthHasVisible) yearHasVisible = true;
      });
      year.hidden = !yearHasVisible;
    });
  }

  function updateArchiveTypeStatus() {
    var statusEl = document.querySelector(".archive-type-status");
    var labelEl = document.querySelector(".archive-type-status-label");
    if (archiveType === "all") {
      statusEl.hidden = true;
    } else {
      labelEl.textContent = "#" + archiveType;
      statusEl.hidden = false;
    }
  }

  function toggleArchiveType(type, button) {
    if (archiveType === type) {
      archiveType = "all";
      button.classList.remove("is-active");
    } else {
      archiveType = type;
      document.querySelectorAll(".archive-type-pill").forEach(function (el) {
        el.classList.toggle("is-active", el === button);
      });
    }
    updateArchiveTypeStatus();
    applyArchiveFilters();
  }

  function clearArchiveType() {
    archiveType = "all";
    document.querySelectorAll(".archive-type-pill").forEach(function (el) {
      el.classList.remove("is-active");
    });
    updateArchiveTypeStatus();
    applyArchiveFilters();
  }

  function setArchiveYear(year) {
    archiveYear = year;
    applyArchiveFilters();
  }
</script>
