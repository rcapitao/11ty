---
layout: base.njk
title: Arquivo
permalink: /arquivo/
---
{%- set groups = collections.posts | groupPostsByYearMonth %}
<h1>Arquivo</h1>

<div class="bearming-archive-controls">
  <div class="bearming-archive-select">
    <select onchange="filterArchiveByType(this.value)" aria-label="Selecionar tipo">
      <option value="all">Todas as publicações ({{ collections.posts.length }})</option>
      <option value="posts">Posts ({{ collections.blogPosts.length }})</option>
      <option value="notas">Notas ({{ collections.notasPosts.length }})</option>
    </select>
  </div>
  <div class="bearming-archive-select">
    <select onchange="if (this.value) location.hash = this.value" aria-label="Selecionar ano">
      <option value="">Todos os anos ({{ collections.posts.length }})</option>
      {%- for group in groups %}
      <option value="#ano-{{ group.id }}">{{ group.year }} ({{ group.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <div class="bearming-archive-select">
    <select onchange="if (this.value) location.hash = this.value" aria-label="Selecionar mês">
      <option value="">Todos os meses</option>
      {%- for group in groups %}
      {%- for month in group.months %}
      <option value="#mes-{{ month.id }}">{{ month.name }} de {{ group.year }} ({{ month.count }})</option>
      {%- endfor %}
      {%- endfor %}
    </select>
  </div>
</div>

{%- for group in groups %}
<section class="archive-year" id="ano-{{ group.id }}">
  <h2>{{ group.year }} <span class="bearming-archive-count">({{ group.count }} post{{ "s" if group.count != 1 }})</span></h2>
  {%- for month in group.months %}
  <div class="archive-month-group" id="mes-{{ month.id }}">
    <h3 class="bearming-archive-month">{{ month.name }} de {{ group.year }} <span class="bearming-archive-count">({{ month.count }} post{{ "s" if month.count != 1 }})</span></h3>
    <ul class="blog-posts">
      {%- for post in month.posts %}
      <li data-type="{{ 'notas' if post.data.tags and 'notas' in post.data.tags else 'posts' }}">
        <span>{{ post.date | shortDate }}</span>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      {%- endfor %}
    </ul>
  </div>
  {%- endfor %}
</section>
{%- endfor %}

<script>
  function filterArchiveByType(type) {
    document.querySelectorAll(".archive-month-group").forEach(function (group) {
      var anyVisible = false;
      group.querySelectorAll("li[data-type]").forEach(function (li) {
        var show = type === "all" || li.dataset.type === type;
        li.hidden = !show;
        if (show) anyVisible = true;
      });
      group.hidden = !anyVisible;
    });
    document.querySelectorAll(".archive-year").forEach(function (year) {
      var anyVisible = false;
      year.querySelectorAll(".archive-month-group").forEach(function (group) {
        if (!group.hidden) anyVisible = true;
      });
      year.hidden = !anyVisible;
    });
  }
</script>
