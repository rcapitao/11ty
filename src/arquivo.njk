---
layout: base.njk
title: Arquivo
permalink: /arquivo/
---
<h1>Arquivo</h1>

<ul class="post-list">
  {%- for post in collections.posts %}
  <li>
    <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
  </li>
  {%- endfor %}
</ul>
