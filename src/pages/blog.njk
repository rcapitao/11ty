---
layout: base.njk
title: Blog
permalink: /blog/
navigationConfig:
  key: Blog
  order: 2
---
{%- set groups = collections.posts | groupPostsByYearMonth %}
<h1>Blog</h1>

<p class="archive-intro">{{ collections.posts.length }} publicaç{{ "ão" if collections.posts.length == 1 else "ões" }}, organizadas por mês. <a href="/feed.xml">Feed RSS</a> · <a href="/feed.json">Feed JSON</a></p>

<p class="archive-browse-label">Navegar por ano</p>
<div class="archive-year-pills">
  {%- for group in groups %}
  <a href="#ano-{{ group.year }}" class="archive-year-pill{{ ' is-current' if group.year == currentYear }}">{{ group.year }} <span class="archive-year-count">({{ group.count }})</span></a>
  {%- endfor %}
</div>

{%- for group in groups %}
<h2 id="ano-{{ group.year }}" class="archive-year-heading">{{ group.year }}</h2>
{%- for month in group.months %}
<div class="archive-month-group">
  <h3 class="bearming-archive-month">{{ month.name }} <span class="bearming-archive-count">({{ month.count }} publicaç{{ "ão" if month.count == 1 else "ões" }})</span></h3>
  <ul class="archive-list">
    {%- for post in month.posts %}
    <li>
      <a href="{{ post.url }}" class="archive-entry-title">{{ post.data.title }}</a>
      <p class="archive-entry-meta">
        {%- for tag in post.data.tags %}
        <a href="/tags/{{ tag }}/" class="archive-entry-tag">{{ tag }}</a>
        {%- endfor %}
        <span class="archive-entry-date">
          <svg class="post-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          {{ post.date | shortDate }}
        </span>
      </p>
    </li>
    {%- endfor %}
  </ul>
</div>
{%- endfor %}
{%- endfor %}
