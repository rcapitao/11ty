---
layout: base.njk
title: Blog
permalink: "/blog/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}"
navigationConfig:
  key: Blog
  order: 2
pagination:
  data: collections.content
  size: 25
  alias: pagePosts
---
{%- set groups = pagePosts | groupPostsByYearMonth %}
<h1>Blog</h1>

{%- for group in groups %}
{%- for month in group.months %}
<div class="archive-month-group">
  <h3 class="bearming-archive-month">{{ month.name }} de {{ group.year }} <span class="bearming-archive-count">({{ month.count }} publicaç{{ "ão" if month.count == 1 else "ões" }})</span></h3>
  <ul class="blog-posts">
    {%- for post in month.posts %}
    <li>
      <span class="post-date">{{ post.date | shortDate }}</span>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <span class="content-type">{{ "Nota" if "notas" in post.data.tags else "Post" }}</span>
    </li>
    {%- endfor %}
  </ul>
</div>
{%- endfor %}
{%- endfor %}

{% include "pagination-nav.njk" %}
